# Copy this file to `.env` and fill in real values locally, or set these as
# environment variables / secrets-manager entries in deployed environments.
# NEVER commit a `.env` file — it is gitignored, and this file must never
# contain a real secret, only placeholders.

# Application
APP_NAME=ApplyFlow
ENVIRONMENT=development
DEBUG=true

# Database
# Local dev defaults to the docker-compose Postgres container. For a
# provisioned Supabase project, use its connection string instead, e.g.
# postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://applyflow:applyflow@localhost:5432/applyflow
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800

# Supabase (database host + auth provider)
# Project URL: Supabase dashboard -> Project Settings -> API -> Project URL
SUPABASE_URL=
# JWT secret: Supabase dashboard -> Project Settings -> API -> JWT Settings -> JWT Secret
# Required whenever ENVIRONMENT is not "development".
SUPABASE_JWT_SECRET=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM / LangChain (OpenAI — used by LangChainResumeAnalyzer)
# Required whenever ENVIRONMENT is not "development".
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
# Embeddings (Epic 00 LLM layer, src/infrastructure/llm/openai_embedding_client.py)
# Anthropic has no embeddings endpoint, so this reuses OPENAI_API_KEY above.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic — the app's single LLM integration (src/infrastructure/llm/anthropic_client.py)
# Must be a pay-as-you-go API key from https://console.anthropic.com/settings/keys.
# Never a claude.ai subscription/session login. Required whenever ENVIRONMENT is not "development".
ANTHROPIC_API_KEY=
# Model routing: callers pass a LlmTaskType (extraction/matching/parsing/
# resume_writing/cover_letter_writing), never a model name. These two
# settings are the only place to override which model answers each tier —
# see src/application/ports/llm_client_port.py (TASK_TYPE_TIERS) for the
# task-type -> tier mapping.
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_STRONG=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=1024
# Retry/backoff for transient errors (rate limits, timeouts, 5xxs). Retries
# happen after the initial attempt, so total attempts = MAX_RETRIES + 1.
# Delay doubles each attempt, starting at BASE and capped at MAX.
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_RETRY_BASE_DELAY_SECONDS=1.0
ANTHROPIC_RETRY_MAX_DELAY_SECONDS=20.0

# Resume file storage — local directory raw resume uploads are written to.
RESUME_STORAGE_DIR=./var/resumes

# Job aggregator integration (reserved for an upcoming adapter)
JOB_AGGREGATOR_API_KEY=
JOB_AGGREGATOR_BASE_URL=

# Search API integration (reserved for an upcoming adapter)
SEARCH_API_KEY=
SEARCH_API_BASE_URL=
