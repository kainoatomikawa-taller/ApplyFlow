# Copy this file to `.env` (or `.env.local`) and adjust per environment.
# Never commit a real `.env` file — it is gitignored.
#
# This is the frontend's config layer: the shell reads which API to talk to
# from this one variable instead of hardcoding an endpoint, so switching
# environments never means editing source. Vite loads it as
# `import.meta.env.VITE_API_URL` (see src/api/client.ts).

# Local development — proxied by vite.config.ts, so this can be left blank
# and requests to /api/* and /health go through the dev server proxy to
# http://localhost:8000.
VITE_API_URL=

# Staging / production — point at the deployed API origin instead, e.g.
# VITE_API_URL=https://api.staging.applyflow.example.com
